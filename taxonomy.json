{
  "version": "1.1",
  "description": "Content Studio 层级分类体系 — 引导式约束。每条约束指向关键决策点，不堆知识。",
  "tree": [
    {
      "id": "文学创作",
      "label": "文学创作",
      "icon": "✍️",
      "constraints": {
        "scope": "虚构/半虚构叙事，以情感共鸣和审美体验为核心",
        "doctrine": [
          "读者在关键节点应感受到你预期的情感——如果感受不到，是你的选择不够具体",
          "每个场景必须有不可替代的叙事功能——删掉它故事会缺一块",
          "情感来自对比：角色失去的东西必须是读者在意的东西"
        ],
        "tone_range": "any",
        "allowed_craft": ["anti-ai-slop", "sentence-rhythm", "sensory-imagery", "chinese-style", "emotional-craft"],
        "forbidden_patterns": []
      },
      "children": [
        {
          "id": "小说",
          "label": "小说",
          "constraints": {
            "scope": "以人物选择和因果链条驱动读者情绪的叙事",
            "doctrine": [
              "人物的选择必须有代价——没有代价的选择不是选择",
              "情节推进靠因果逻辑，不靠巧合——每个「然后」应该回答「为什么」",
              "角色差异靠行为定义：不说ta是什么人，写ta做了什么选择"
            ],
            "tone_range": "any",
            "p0_checks": ["character_choice_has_cost", "plot_driven_by_causality", "no_resurrection_without_cost"]
          },
          "children": [
            {
              "id": "长篇小说",
              "label": "长篇小说 (>80K字)",
              "constraints": {
                "scope": "8万字以上的长篇叙事，允许多线叙事和复杂世界观",
                "doctrine": [
                  "每条剧情线需要在读者忘记它之前兑现——长线需定期提醒存在",
                  "世界观规则在前1/3建立，之后不得无故违反——读者会记住",
                  "每条伏笔的「回收预期」必须在埋设时确立，不要让读者等太久"
                ],
                "tone_range": "any",
                "word_range": [3000, 10000],
                "forbidden_patterns": [
                  "乒乓球式对话（对白无停顿、思考、环境反应——读起来像背台词）",
                  "机械降神（问题解决了，但读者觉得是作者编的不是角色挣的）"
                ],
                "p0_checks": ["character_choice_has_cost", "plot_driven_by_causality", "no_resurrection_without_cost", "foreshadowing_has_payoff"]
              }
            },
            {
              "id": "中篇小说",
              "label": "中篇小说 (20K-80K字)",
              "constraints": {
                "scope": "2-8万字的中篇叙事，单线为主不超过2条支线",
                "doctrine": [
                  "篇幅有限——省去世界观全貌展示，集中火力在核心冲突",
                  "前10%必须建立核心冲突，不要铺垫太久"
                ],
                "word_range": [2000, 8000],
                "forbidden_patterns": ["支线过多让主线失焦"],
                "p0_checks": ["plot_driven_by_causality", "no_resurrection_without_cost"]
              }
            },
            {
              "id": "短篇小说",
              "label": "短篇小说 (<20K字)",
              "constraints": {
                "scope": "2万字以内的短篇叙事，聚焦一个核心事件或情感瞬间",
                "doctrine": [
                  "只讲一个故事——读者看完应该能用一句话说清发生了什么",
                  "前500字必须建立核心困境或情感锚点——没有预热空间",
                  "结尾如果反转，反转必须改变读者对前文的理解"
                ],
                "word_range": [1000, 20000],
                "forbidden_patterns": ["开局铺垫太久", "多线分散核心情感"],
                "p0_checks": ["hook_present", "plot_driven_by_causality"]
              }
            },
            {
              "id": "微型小说",
              "label": "微型小说 (<2K字)",
              "constraints": {
                "scope": "2000字以内的极短篇，突出一个瞬间、一个反转或一个意象",
                "doctrine": [
                  "结尾必须有意外或余味——读者看完应该停顿一下",
                  "去掉一切不是必要的词——每个词都在挣它的位置"
                ],
                "word_range": [100, 2000],
                "forbidden_patterns": ["修饰词过多", "解释结尾"],
                "p0_checks": ["hook_present"]
              }
            }
          ]
        },
        {
          "id": "剧本",
          "label": "剧本",
          "constraints": {
            "scope": "以对白和视觉指示为核心的表演文本",
            "doctrine": [
              "对白是冰山：角色嘴上说十分，心里想十分，说出口的只有三分",
              "舞台指示只写摄像机能看到和录音机能录到的内容",
              "每一句对白应该有对手的反应——没人说话时另一个人在做什么"
            ],
            "tone_range": "any",
            "allowed_craft": ["anti-ai-slop", "sentence-rhythm", "chinese-style"],
            "forbidden_patterns": ["旁白式说明对白（角色说自己是什么人——让别人说出来）"],
            "p0_checks": ["dialogue_is_subtext", "stage_direction_is_visual"]
          }
        },
        {
          "id": "诗歌",
          "label": "诗歌",
          "constraints": {
            "scope": "以意象和节奏为核心的诗性文本",
            "doctrine": [
              "找到一个核心意象，用它贯穿全诗——诗读完读者记住的是这个画面",
              "节奏服务于情感走向——长句舒缓，短句急促，断句制造呼吸"
            ],
            "tone_range": "any",
            "allowed_craft": ["sentence-rhythm", "sensory-imagery", "chinese-style"],
            "forbidden_patterns": ["直白抒情（你感到什么不重要，读者感到什么才重要）", "悲情词汇堆砌"]
          }
        },
        {
          "id": "散文",
          "label": "散文",
          "constraints": {
            "scope": "以真实体验和感悟为基础的文学性随笔",
            "doctrine": [
              "细节越具体越有力——「他抽了根烟」比「他很焦虑」更有画面",
              "一事一议——一篇散文只做一件事：让读者对一件事有了新的看法"
            ],
            "tone_range": "any",
            "allowed_craft": ["anti-ai-slop", "sensory-imagery", "chinese-style"],
            "forbidden_patterns": ["概括代替描写", "大词抒情"]
          }
        },
        {
          "id": "儿童文学",
          "label": "儿童文学",
          "constraints": {
            "scope": "面向儿童的文学作品，分年龄段创作",
            "doctrine": [
              "语言难度匹配目标年龄段——6岁孩子读不懂「深邃」，但能读懂「很深很深」",
              "主角年龄应接近目标读者年龄——孩子通过主角的眼睛看世界"
            ],
            "tone_range": "warm",
            "allowed_craft": ["anti-ai-slop", "sensory-imagery", "chinese-style"],
            "forbidden_patterns": ["过度恐怖描写", "抽象概念无具象对应"],
            "p0_checks": ["age_appropriate_language"]
          },
          "children": [
            {
              "id": "童话",
              "label": "童话",
              "constraints": {
                "scope": "以幻想元素承载教育或情感启蒙的短篇儿童故事",
                "doctrine": [
                  "最后留一句话让孩子记住——不用教条，用故事自已说出"
                ]
              }
            },
            {
              "id": "少儿小说",
              "label": "少儿小说",
              "constraints": {
                "scope": "面向6-14岁儿童的阶段性小说",
                "doctrine": [
                  "价值观通过选择和后果呈现，不是说出来的"
                ]
              }
            },
            {
              "id": "绘本文字",
              "label": "绘本文字",
              "constraints": {
                "scope": "配合插图的精简文字，每页不超过100字",
                "doctrine": [
                  "文字说画面没说的事——图和字各说一半，读者在中间相遇"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "商业写作",
      "label": "商业写作",
      "icon": "💼",
      "constraints": {
        "scope": "以商业目的为核心的应用写作，追求清晰、高效和说服力",
        "doctrine": [
          "读者读完第一段应该知道「这跟我有什么关系」",
          "每个结论背后必须有证据——没有证据的结论是观点，不是事实",
          "如果一句话删掉后读者获得的信息不变，删掉它"
        ],
        "tone_range": ["formal", "neutral"],
        "allowed_craft": ["anti-ai-slop", "sentence-rhythm", "chinese-style"],
        "forbidden_patterns": ["空洞宏大词（颠覆/赋能/闭环——它们很少意味着什么）", "过度承诺"]
      },
      "children": [
        {
          "id": "营销文案",
          "label": "营销文案",
          "constraints": {
            "scope": "以转化为目标的商业推广文本",
            "doctrine": [
              "读者不关心你的产品有什么功能——他们关心自己的问题怎么解决",
              "具体胜过一切：说「省了3小时」比说「高效」有效10倍"
            ],
            "tone_range": ["casual", "neutral"],
            "forbidden_patterns": ["全是形容词无数据"],
            "p0_checks": ["value_proposition_clear", "no_vague_claims"]
          },
          "children": [
            {
              "id": "产品页",
              "label": "产品页面文案",
              "constraints": {
                "scope": "电商或官网产品详情页",
                "doctrine": [
                  "用具体数据替代形容词——「已服务2000+客户」＞「广受好评」"
                ]
              }
            },
            {
              "id": "社媒短文",
              "label": "社交媒体短文",
              "constraints": {
                "scope": "微博/朋友圈/即刻等短文字社交平台",
                "doctrine": [
                  "前3行决定读者是否会继续看——不要浪费在背景介绍上"
                ],
                "word_range": [1, 300]
              }
            }
          ]
        },
        {
          "id": "汇报报告",
          "label": "汇报与报告",
          "constraints": {
            "scope": "工作汇报、数据分析报告、提案",
            "doctrine": [
              "结论先行，数据支撑——决策者先看结论，有兴趣再看细节",
              "每个数据点必须回答「所以呢」——数据本身没有意义，意义来自解读"
            ],
            "tone_range": "formal",
            "forbidden_patterns": ["没有结论的数据堆砌"],
            "p0_checks": ["data_supports_claim", "message_before_data"]
          },
          "children": [
            {
              "id": "周报",
              "label": "周报/月报",
              "constraints": {
                "scope": "周期性工作汇报",
                "doctrine": [
                  "用动词开头写做了什么，不是用名词开头写这是什么"
                ],
                "word_range": [1, 800]
              }
            },
            {
              "id": "调研报告",
              "label": "调研/分析报告",
              "constraints": {
                "scope": "包含数据分析和结论建议的正式报告",
                "doctrine": [
                  "建议必须可执行——「提升效率」不叫建议，「取消每周同步会改用异步文档」才叫建议"
                ]
              }
            }
          ]
        },
        {
          "id": "产品文档",
          "label": "产品文档",
          "constraints": {
            "scope": "产品说明书、API文档、用户指南",
            "doctrine": [
              "用用户的语言，不是技术语言——「保存文件」比「持久化数据」好读",
              "重点解决用户的问题，不是展示功能——按场景组织，不按模块组织"
            ],
            "tone_range": "neutral"
          }
        }
      ]
    },
    {
      "id": "知识输出",
      "label": "知识输出",
      "icon": "📚",
      "constraints": {
        "scope": "以知识传递和技能培养为核心的教育性内容",
        "doctrine": [
          "每个概念必须配一个例子——没有例子的概念读者记不住",
          "从读者已知的出发，走向未知的——不要假设读者和你知识水平一样",
          "结构要清晰到读者可以跳着看——每个章节标题是该节的答案"
        ],
        "tone_range": ["neutral", "warm"],
        "allowed_craft": ["anti-ai-slop", "sentence-rhythm", "chinese-style"],
        "forbidden_patterns": ["默认读者已经懂了某个前置概念"]
      },
      "children": [
        {
          "id": "课程脚本",
          "label": "课程与教程",
          "constraints": {
            "scope": "线上课程、视频脚本、教程指南",
            "doctrine": [
              "每段只讲一件事——观众跟不上就回不来了",
              "内容块的数量控制在7±2以内——人的工作记忆上限"
            ],
            "tone_range": "warm",
            "p0_checks": ["example_provided", "learning_objective_clear"]
          },
          "children": [
            {
              "id": "视频脚本",
              "label": "课程视频脚本",
              "constraints": {
                "scope": "配合视频画面的口播脚本",
                "doctrine": [
                  "每段时长控制在90秒以内——超过这个时间注意力开始下降",
                  "口语化但不口语滥用——像正常说话，但不等于用废话填时间"
                ]
              }
            },
            {
              "id": "教程指南",
              "label": "图文教程/指南",
              "constraints": {
                "scope": "可打印或在线阅读的步骤式指南",
                "doctrine": [
                  "步骤编号清晰——每一步都应该是读者可以完成的一个动作",
                  "每个步骤配截图或示意图——「看到对了吗」比「对不对」重要"
                ]
              }
            }
          ]
        },
        {
          "id": "深度分析",
          "label": "深度分析与科普",
          "constraints": {
            "scope": "对特定主题的深入研究或科普文章",
            "doctrine": [
              "专业度匹配目标读者——写给同行可以上术语，写给大众必须拆概念",
              "每个结论要有可验证的来源——不是「研究表明」，是「2024年Nature论文显示」"
            ],
            "word_range": [1, 3000],
            "p0_checks": ["data_or_evidence", "key_message_clear"]
          }
        }
      ]
    },
    {
      "id": "媒体社交",
      "label": "媒体与社交",
      "icon": "📱",
      "constraints": {
        "scope": "面向社交媒体的短内容创作",
        "doctrine": [
          "第一句话决定这个帖子90%的命运——写完后问自己：这行字能让人停下吗？",
          "每个平台有自己的说话方式——在小红书写得像公众号发言是错的",
          "社交媒体的本质是对话——帖子不是广播，是邀请别人加入对话"
        ],
        "tone_range": ["casual", "warm"],
        "allowed_craft": ["anti-ai-slop", "sensory-imagery", "chinese-style"],
        "forbidden_patterns": ["官方口吻", "跨平台复制粘贴"]
      },
      "children": [
        {
          "id": "社媒帖子",
          "label": "社媒帖子",
          "constraints": {
            "scope": "各社交平台的原生帖子",
            "doctrine": [
              "同一个内容在不同平台要说不同的话——不是复制，是翻译"
            ],
            "p0_checks": ["hook_present"]
          },
          "children": [
            {
              "id": "小红书",
              "label": "小红书笔记",
              "constraints": {
                "scope": "种草/分享/教程类小红书笔记",
                "doctrine": [
                  "多分段，每段不超过3行——手机屏幕上看大段文字是折磨",
                  "结尾加上话题标签帮助搜索——但标签不是标题"
                ]
              }
            },
            {
              "id": "公众号",
              "label": "公众号推文",
              "constraints": {
                "scope": "微信公众号长文推文",
                "doctrine": [
                  "标题在25字内说清「这篇文章能给我什么」",
                  "文中至少3个小标题——读者是扫视的不是逐字读的"
                ]
              }
            },
            {
              "id": "微博",
              "label": "微博短文",
              "constraints": {
                "scope": "微博短文或头条文章",
                "doctrine": [
                  "前40字决定展开还是不展开——写最重要的信息, 不用铺垫"
                ]
              }
            }
          ]
        },
        {
          "id": "新闻通讯",
          "label": "新闻与通讯",
          "constraints": {
            "scope": "新闻稿、通讯稿、简报",
            "doctrine": [
              "最重要的信息放在第一段——读者可能只看这一段",
              "客观陈述事实，不夹带个人观点——让读者自己判断"
            ],
            "tone_range": "neutral"
          }
        }
      ]
    },
    {
      "id": "学术专业",
      "label": "学术专业",
      "icon": "🎓",
      "constraints": {
        "scope": "学术研究、技术文档、专业领域的规范性写作",
        "doctrine": [
          "每个非共识的结论必须有可验证的来源——没有来源的断言等于猜测",
          "结构遵循该领域标准格式——审稿人和读者有预期，满足他们的预期",
          "用词精确——「可能」「大概」「某种程度上」在学术写作中是红色警报"
        ],
        "tone_range": "formal",
        "allowed_craft": ["sentence-rhythm", "chinese-style"],
        "forbidden_patterns": ["无来源的断言", "模糊修饰语滥用"]
      },
      "children": [
        {
          "id": "论文",
          "label": "学术论文",
          "constraints": {
            "scope": "学术期刊论文、学位论文",
            "doctrine": [
              "摘要应让不读正文的人也能get到核心贡献——这不是引言缩写",
              "引用格式不是形式问题——错误的引用格式暗示审稿人你对细节不认真"
            ],
            "p0_checks": ["citation_format", "structure_complete"],
            "allowed_craft": ["sentence-rhythm", "chinese-style"]
          }
        },
        {
          "id": "技术文档",
          "label": "技术文档",
          "constraints": {
            "scope": "API文档、技术规格、架构说明",
            "doctrine": [
              "代码示例必须可运行——读者会复制粘贴，跑不通就是你文档的信任危机",
              "用词统一——同一个概念全文用同一个词，不要同义替换"
            ]
          }
        },
        {
          "id": "研究笔记",
          "label": "研究笔记与草稿",
          "constraints": {
            "scope": "个人研究过程中的思考记录和不完整草稿",
            "doctrine": [
              "标注每段的状态——这是结论、猜想还是待验证的问题？让未来的你知道当时在想什么"
            ],
            "tone_range": "any"
          }
        }
      ]
    }
  ]
}
